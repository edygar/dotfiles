{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "qr-code",
  "title": "QR Code",
  "description": "Generate QR codes from text or URLs",
  "icon": "extension-icon.png",
  "author": "jerome_soyer",
  "categories": [
    "Productivity",
    "Developer Tools"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "generate-qr-code",
      "title": "Generate QR Code",
      "subtitle": "QR Code",
      "description": "Generate a QR code from text or a URL",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.6",
    "@raycast/utils": "^2.2.2",
    "qrcode": "^1.5.4"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "25.3.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "19.2.14",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}

{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "chrome",
  "title": "Chrome",
  "description": "Control Google Chrome via AppleScript",
  "icon": "extension-icon.png",
  "author": "jerome_soyer",
  "categories": [
    "Applications",
    "Productivity"
  ],
  "license": "MIT",
  "commands": [
    {
      "name": "move-tab-to-window",
      "title": "Move Tab to Window",
      "subtitle": "Chrome",
      "description": "Move the active tab to another Chrome window",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.104.6",
    "@raycast/utils": "^2.2.2"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^2.1.1",
    "@types/node": "25.3.0",
    "@types/react": "19.2.14",
    "eslint": "^10.0.2",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "prepublishOnly": "echo \"Error: no publish\" && exit 1",
    "publish": "npx @raycast/api@latest publish"
  },
  "platforms": [
    "macOS"
  ]
}